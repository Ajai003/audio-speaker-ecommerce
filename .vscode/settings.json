{
  "css.customData": [".vscode/cssdata.json"],
  "css.validate": false,
  "scss.validate": false,
  "less.validate": false,
  "postcss.validate": false,
  "css.lint.unknownAtRules": "ignore",
  "scss.lint.unknownAtRules": "ignore",
  "postcss.lint.unknownAtRules": "ignore",
  "files.associations": {
    "app/**/*.css": "tailwindcss",
    "components/**/*.css": "tailwindcss",
    "lib/**/*.css": "tailwindcss",
    "*.css": "tailwindcss"
  },
  "tailwindCSS.experimental.classRegex": [
    ["cva\\(([^)]*)\\)", "[\"'`]([^\"'`]*)[\"'`]"]
  ]
}
